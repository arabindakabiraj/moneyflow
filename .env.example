# MoneyFlow Environment Variables
# Copy this file as .env and fill in your own values

# Google Apps Script Web App URL
# (Google Sheets → Extensions → Apps Script → Deploy → New Deployment → Web App URL)
VITE_GAS_URL=your_gas_web_app_url_here

# Gemini API Key
# (aistudio.google.com → Get API Key → Create)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API Key (optional, for AI chat)
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here
