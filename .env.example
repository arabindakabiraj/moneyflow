# MoneyFlow Environment Variables
# Copy this file as .env and fill in your own values

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
DATABASE_URL=postgresql://postgres:[db-password]@db.[project-id].supabase.co:5432/postgres

# OpenRouter API Key (optional, for AI chatbot features)
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here
